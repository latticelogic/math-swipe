# Copy to .env and fill in from Firebase console → Project Settings → General
# These keys are public (shipped in every client) — security is enforced by
# Firestore Rules + App Check, not by hiding them.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Payment provider — 'airwallex' (default) or 'stripe'. Selects which callable
# the client invokes; the matching Cloud Function must have its secrets set +
# be deployed. See docs/airwallex.md.
VITE_PAYMENT_PROVIDER=airwallex

# App Check (reCAPTCHA v3) — optional but strongly recommended for prod.
# The reCAPTCHA v3 site key from Firebase console → App Check → Apps → your web
# app. When unset, App Check is a no-op (local dev / preview work unchanged).
# See docs/app-check.md for provisioning + turning on enforcement.
VITE_APPCHECK_SITE_KEY=

# Web Push (FCM) — optional. Generate at:
#   Firebase console → Project Settings → Cloud Messaging → Web configuration
# When unset, the notifications opt-in UI in the Me tab shows a "coming soon"
# hint instead of failing. The companion Cloud Function in functions/ also
# needs deploying before any notification actually goes out.
VITE_VAPID_PUBLIC_KEY=
