<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- No action bar; chalkboard background so first paint matches the PWA and
         there's no white flash before the WebView loads. ComponentActivity
         works with a plain Material theme (no AppCompat dependency needed).

         Bars are transparent + the window draws edge-to-edge: the web app is
         built with viewport-fit=cover and env(safe-area-inset-*), so it lays
         out its own content under the status/nav bars correctly. Solid bar
         colours would double up with the web app's safe-area padding. -->
    <style name="Theme.MathChallenge" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/board</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:colorBackground">@color/board</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Launch (cold-start) theme. installSplashScreen() shows this, then swaps
         to postSplashScreenTheme once the activity is up; MainActivity keeps it
         on screen until the WebView paints its first frame. -->
    <style name="Theme.MathChallenge.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/board</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.MathChallenge</item>
    </style>
</resources>
